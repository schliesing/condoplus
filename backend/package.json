{
  "name": "condoplus-backend",
  "version": "0.1.0",
  "description": "CondoPlus - Multi-tenant Condo Management API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/scripts/migrate.js",
    "seed": "node src/scripts/seed.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest __tests__/services/",
    "test:integration": "jest __tests__/routes/",
    "test:auth": "jest __tests__/routes/auth.test.js",
    "test:votings": "jest __tests__/routes/votings.test.js",
    "test:scheduling": "jest __tests__/routes/scheduling.test.js",
    "test:suppliers": "jest __tests__/routes/suppliers.test.js",
    "test:notifications": "jest __tests__/routes/notifications.test.js",
    "test:routes": "jest __tests__/routes/",
    "test:all-routes": "jest __tests__/routes/ --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:coverage": "jest --coverage --coverageReporters=html && open coverage/index.html"
  },
  "keywords": ["condo", "management", "voting", "scheduling"],
  "author": "CondoPlus Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.10.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-validator": "^7.0.0",
    "axios": "^1.6.0",
    "node-cron": "^3.0.2",
    "twilio": "^4.19.0",
    "@sendgrid/mail": "^8.1.0",
    "googleapis": "^128.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  }
}
