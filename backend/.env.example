# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=condoplus
DB_ADMIN_SCHEMA=public

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h

# Server
PORT=3000
NODE_ENV=development

# Google Calendar
GOOGLE_CALENDAR_CREDENTIALS={}
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Digital Signature (placeholder - to be implemented later)
SIGNATURE_API_KEY=
SIGNATURE_API_URL=

# WhatsApp/SMS (to be implemented later)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Email (Gmail or SendGrid)
GMAIL_USER=
GMAIL_APP_PASSWORD=
SENDGRID_API_KEY=

# Storage (S3 or GCS for PDFs)
AWS_S3_BUCKET=
AWS_S3_REGION=
AWS_S3_ACCESS_KEY=
AWS_S3_SECRET_KEY=

# Logging
LOG_LEVEL=debug
